{
  "name": "pong-cli",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run serve",
    "build": "npm run build:prepare && npm run build:css && npm run build:js && npm run build:copy",
    "build:prepare": "rm -rf dist && mkdir -p dist",
    "build:css": "tailwindcss -i ./src/style.css -o ./dist/style.css",
    "build:js": "tsc",
    "build:copy": "cp -r public/* dist/ && cp index.html dist/",
    "serve": "http-server dist -p 8080 -c-1 --cors -a 0.0.0.0",
    "preview": "http-server dist -p 8080"
  },
  "devDependencies": {
    "@types/node": "^24.0.13",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.5.3"
  },
  "dependencies": {
    "i18next": "^23.12.2",
    "i18next-http-backend": "^2.5.2"
  }
}
